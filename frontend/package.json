{
  "name": "frontend",
  "version": "0.0.0",
  "author": "Oleg Baryshev",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 4173",
    "test:unit": "vitest --ui",
    "test:e2e": "start-server-and-test preview http://localhost:4173/ 'cypress open --e2e'",
    "test:e2e:ci": "start-server-and-test preview http://localhost:4173/ 'cypress run --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "svgo:mono": "svgo -f ./src/assets/svg/mono/ --config svgo.mono.config.js"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tailwindcss/forms": "^0.5.3",
    "@vuelidate/core": "^2.0.0",
    "@vuelidate/validators": "^2.0.0",
    "@vuepic/vue-datepicker": "^3.6.3",
    "@vueuse/components": "^10.4.1",
    "@vueuse/core": "^10.4.1",
    "@vueuse/router": "^10.4.1",
    "animate.css": "^4.1.1",
    "axios": "^1.2.6",
    "caniuse-lite": "^1.0.30001519",
    "date-fns": "^2.29.3",
    "floating-vue": "^2.0.0-beta.20",
    "lodash": "^4.17.21",
    "maska": "^2.1.6",
    "overlayscrollbars": "^2.0.3",
    "pinia": "^2.2.2",
    "three": "^0.179.1",
    "tw-elements": "^1.0.0-alpha13",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue": "^3.5.11",
    "vue-collapsed": "^1.2.6",
    "vue-dndrop": "^1.3.1",
    "vue-imask": "^6.4.3",
    "vue-router": "^4.4.5",
    "vue-toastification": "^2.0.0-rc.5",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue3-click-away": "^1.2.4",
    "vueuc": "^0.4.64"
  },
  "devDependencies": {
    "@types/body-scroll-lock": "^3.1.0",
    "@types/jsdom": "^20.0.0",
    "@types/lodash": "^4.14.191",
    "@types/node": "^16.11.56",
    "@types/three": "^0.179.0",
    "@types/vue-virtual-scroller": "npm:@earltp/vue-virtual-scroller@^1.0.1",
    "@vitejs/plugin-vue": "^4.3.4",
    "@vitejs/plugin-vue-jsx": "^3.0.2",
    "@vitest/coverage-v8": "^0.34.4",
    "@vitest/ui": "^0.34.4",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/test-utils": "^2.0.2",
    "@vue/tsconfig": "^0.1.3",
    "autoprefixer": "^10.4.13",
    "cypress": "^13.16.1",
    "eslint": "^8.30.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-vue": "^9.3.0",
    "git-describe": "^4.1.1",
    "jsdom": "^20.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.19",
    "sass": "^1.55.0",
    "start-server-and-test": "^2.0.9",
    "svgo": "^3.0.2",
    "tailwindcss": "^3.2.4",
    "typescript": "~4.7.4",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.24.1",
    "vite": "^4.4.9",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-glsl": "^1.5.1",
    "vite-plugin-inspect": "^0.7.38",
    "vite-svg-loader": "^4.0.0",
    "vitest": "^0.34.4",
    "vue-tsc": "^0.40.7",
    "wowjs": "^1.1.3"
  }
}
